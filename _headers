# Shells: revalidar en cada carga (no-cache) → el usuario siempre corre el último
# código, sin quedar pegado a una versión vieja (el problema de los minutos en celu).
# El contenido vivo viene por /api/* (lo maneja el Worker), así que el HTML puede revalidar.
/mundial2026.html
  Cache-Control: no-cache

/plantel.html
  Cache-Control: no-cache

/partido.html
  Cache-Control: no-cache

/flags/*
  Cache-Control: public, max-age=86400, s-maxage=86400

/copa.avif
  Cache-Control: public, max-age=86400, s-maxage=86400
